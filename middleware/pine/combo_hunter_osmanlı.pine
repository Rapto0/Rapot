h_kpbOS   = input.int(0,     "OS",           group=grpH, inline="h16")
h_mFast   = input.int(12,    "MACD F/S",     group=grpH, inline="h17")
h_mSlow   = input.int(26,    "",             group=grpH, inline="h17")
