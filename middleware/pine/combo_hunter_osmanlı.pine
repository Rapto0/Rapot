// GENEL
// ══════════════════════════════════════════════════════════════
grpG = "⚙ Genel"
confirmClose   = input.bool(false, "Sinyali yalnızca bar kapanışında doğrula", group=grpG)
showTable      = input.bool(true,  "Bilgi tablosunu göster", group=grpG)
MAX_BARS       = input.int(60,     "HTF geçmiş bar limiti", group=grpG, minval=30, maxval=200)

// ══════════════════════════════════════════════════════════════
// WATCHLIST / DISPATCHER
// ══════════════════════════════════════════════════════════════
grpA = "🔔 Watchlist Alarm"
enableWatchlist = input.bool(true, "Watchlist dispatcher aktif", group=grpA)
watchlistIntrabar = input.bool(true, "Watchlist alarmı gün içinde çalışsın", group=grpA, tooltip="Açık: realtime bar içinde koşul oluşunca alarm gönderir.\nKapalı: yalnızca kapanış iterasyonunda gönderir.")
payloadMode = input.string("JSON", "Watchlist payload", options=["JSON", "Compact"], group=grpA)
multiSignalMode = input.string("ALL", "Aynı barda çoklu sinyal", options=["ALL", "FIRST"], group=grpA, tooltip="ALL: aynı barda true olan tüm sinyaller ayrı ayrı gönderilir.\nFIRST: aynı barda yalnızca ilk sinyal gönderilir.")

