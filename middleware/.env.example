# Middleware runtime
MW_APP_NAME=rapot-trading-middleware
MW_APP_ENV=development
MW_LOG_LEVEL=INFO

# Postgres connection (recommended for production)
MW_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rapot_middleware

# Execution safety (default safe mode)
MW_EXECUTION_MODE=DRY_RUN
MW_TRADING_ENABLED=false
MW_BROKER_NAME=MOCK
MW_ALLOW_ADMIN_ENDPOINTS=true
MW_REQUIRE_WEBHOOK_AUTH=true
MW_WEBHOOK_AUTH_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN

# Sizing
MW_BASE_BUDGET_TL=10000
MW_BUY_BPS=20
MW_SELL_BPS=20
MW_MAX_OPEN_TRANCHES_PER_SYMBOL=4

# Signal multipliers
MW_MULTIPLIER_H_BLS=1.00
MW_MULTIPLIER_H_UCZ=0.50
MW_MULTIPLIER_C_BLS=1.00
MW_MULTIPLIER_C_UCZ=0.50

# Tick policy
MW_DEFAULT_TICK_SIZE=0.01
# JSON object, example: {"THYAO":"0.05","GARAN":"0.01"}
MW_SYMBOL_TICK_OVERRIDES_JSON={}

# Optional guard rails
MW_MAX_SYMBOL_EXPOSURE_TL=
MW_MAX_DAILY_LOSS_TL=
MW_MAX_ORDERS_PER_DAY=
MW_ALLOWED_SYMBOLS_CSV=
MW_MAX_SIGNAL_AGE_SECONDS=
MW_MAX_SIGNAL_FUTURE_SKEW_SECONDS=120
MW_REQUIRE_REALTIME_SIGNALS=false

# Mock broker behavior
MW_MOCK_AUTO_FILL=true

# Binance Spot adapter (DRY_RUN uses testnet/public exchangeInfo by default)
MW_BINANCE_LIVE_ENABLED=false
MW_BINANCE_BASE_URL=https://testnet.binance.vision
MW_BINANCE_API_KEY=
MW_BINANCE_SECRET_KEY=
MW_BINANCE_REQUEST_TIMEOUT_SECONDS=10
MW_BINANCE_RECV_WINDOW_MS=5000
MW_BINANCE_BUY_QUOTE_AMOUNT_USDT=25
MW_BINANCE_QUOTE_ASSET=USDT
MW_BINANCE_DRY_RUN_AUTO_FILL=true
MW_BINANCE_CHECK_BALANCE=true

# Osmanli live adapter gates (keep disabled until official UAT sign-off)
MW_OSMANLI_LIVE_ENABLED=false
MW_OSMANLI_BASE_URL=
MW_OSMANLI_TOKEN_URL=
MW_OSMANLI_ACCOUNT_ID=
MW_OSMANLI_CLIENT_ID=
MW_OSMANLI_CLIENT_SECRET=
MW_OSMANLI_REQUEST_TIMEOUT_SECONDS=10

# Osmanli TradingView JSON command proxy (Model A, disabled by default)
MW_OSMANLI_TV_WEBHOOK_URL=
MW_OSMANLI_FORWARD_ENABLED=false
MW_OSMANLI_FORWARD_TIMEOUT_SECONDS=5
