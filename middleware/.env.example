# Middleware runtime
MW_APP_NAME=rapot-trading-middleware
MW_APP_ENV=development
MW_LOG_LEVEL=INFO

# Postgres connection (recommended for production)
MW_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rapot_middleware

# Execution safety (default safe mode)
MW_EXECUTION_MODE=DRY_RUN
MW_TRADING_ENABLED=false
MW_BROKER_NAME=MOCK
MW_ALLOW_ADMIN_ENDPOINTS=true
MW_WEBHOOK_AUTH_TOKEN=

# Sizing
MW_BASE_BUDGET_TL=10000
MW_BUY_BPS=20
MW_SELL_BPS=20
MW_MAX_OPEN_TRANCHES_PER_SYMBOL=4

# Signal multipliers
MW_MULTIPLIER_H_BLS=1.00
MW_MULTIPLIER_H_UCZ=0.50
MW_MULTIPLIER_C_BLS=1.00
MW_MULTIPLIER_C_UCZ=0.50

# Tick policy
MW_DEFAULT_TICK_SIZE=0.01
# JSON object, example: {"THYAO":"0.05","GARAN":"0.01"}
MW_SYMBOL_TICK_OVERRIDES_JSON={}

# Optional guard rails
MW_MAX_SYMBOL_EXPOSURE_TL=
MW_MAX_DAILY_LOSS_TL=
MW_MAX_ORDERS_PER_DAY=
MW_ALLOWED_SYMBOLS_CSV=

# Mock broker behavior
MW_MOCK_AUTO_FILL=true
