TELEGRAM_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

BINANCE_API_KEY=
BINANCE_SECRET_KEY=

GEMINI_API_KEY=your_gemini_api_key_here
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

AI_ENABLED=1
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_ENABLE_FALLBACK=false
AI_FALLBACK_MODEL=
AI_TIMEOUT=30
AI_TEMPERATURE=0.2
AI_THINKING_BUDGET=0
AI_MAX_OUTPUT_TOKENS=2048

# Database: use DATABASE_URL for Postgres/MySQL, otherwise SQLite path
DATABASE_URL=
DATABASE_PATH=trading_bot.db
CACHE_DATABASE_PATH=price_cache.db

FINNHUB_API_KEY=
CALENDAR_CACHE_SECONDS=60

APP_ENV=production
RUN_EMBEDDED_BOT=0

# REQUIRED in production: do not keep placeholder values.
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_64_HEX_SECRET
JWT_EXPIRE_MINUTES=1440
ALLOW_INSECURE_JWT_SECRET=0

# Optional in local/dev only
ADMIN_PASSWORD=
USER_PASSWORD=
ADMIN_PASSWORD_HASH=
USER_PASSWORD_HASH=

# CORS (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=1
